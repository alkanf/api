  "item": [
    {
      "name": "Add a Student",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const randomCountry = pm.variables.replaceIn('{{$randomCountry}}');\r",
              "const randomUsername = pm.variables.replaceIn('{{$randomFirstName}}');\r",
              "const randomPhone = pm.variables.replaceIn('{{$randomPhoneNumber}}');\r",
              "\r",
              "pm.collectionVariables.set(\"country\", randomCountry);\r",
              "pm.collectionVariables.set(\"username\", randomUsername);\r",
              "pm.collectionVariables.set(\"phone\", randomPhone);\r",
              "\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "const response = pm.response.json();\r",
              "pm.collectionVariables.set(\"id\", response.id);\r",
              "\r",
              "\r",
              "\r",
              "pm.test(\"Status code is 201\", ()=> {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"name\": \"{{username}}\",\r\n  \"location\": \"{{country}}\",\r\n  \"phone\": \"{{phone}}\",\r\n  \"courses\": [\r\n    \"JavaScript\",\r\n    \"Postman\"\r\n  ]\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseURL}}students",
          "host": [
            "{{baseURL}}students"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get Student",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "const response = pm.response.json();\r",
              "\r",
              "pm.test(\"Status code is 200\", ()=> {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response body should have correct data\", () => {\r",
              "    pm.expect(response.id).to.eql(pm.collectionVariables.get(\"id\"));\r",
              "    pm.expect(response.name).to.eql(pm.collectionVariables.get(\"username\"));\r",
              "    pm.expect(response.location).to.eql(pm.collectionVariables.get(\"country\"));\r",
              "    pm.expect(response.phone).to.eql(pm.collectionVariables.get(\"phone\"));\r",
              "});\r",
              "\r",
              "    \r",
              ""
