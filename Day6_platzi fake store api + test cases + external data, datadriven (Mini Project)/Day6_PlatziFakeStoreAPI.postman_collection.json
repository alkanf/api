        {
          "name": "Get All Products",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();\r",
                  "const id = response[0].id;\r",
                  "const slug = response[0].slug;\r",
                  "const title = response[0].title;\r",
                  "const price = response[0].price;\r",
                  "const categoryID = response[0].category.id;\r",
                  "const categorySlug = response[0].category.slug;\r",
                  "pm.collectionVariables.set(\"id\", id);\r",
                  "pm.collectionVariables.set(\"slug\", slug);\r",
                  "pm.collectionVariables.set(\"title\", title);\r",
                  "pm.collectionVariables.set(\"price\", price);\r",
                  "pm.collectionVariables.set(\"categoryID\", categoryID);\r",
                  "pm.collectionVariables.set(\"categorySlug\", categorySlug);\r",
                  "\r",
                  "pm.test(\"Status code is 200\",  ()=> {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "pm.test(\"Validate array is not empty and has items\", () => {\r",
                  "    pm.expect(response).to.be.an('array').that.is.not.empty;\r",
                  "});\r",
                  "\r",
                  "// JSON Schema Test\r",
                  "const productSchema = {\r",
                  "    \"type\": \"array\", // Ana yapı bir array (liste)\r",
                  "    \"items\": {\r",
                  "        \"type\": \"object\",\r",
                  "        \"required\": [\"id\", \"title\", \"price\", \"description\", \"category\", \"images\"],\r",
                  "        \"properties\": {\r",
                  "            \"id\": { \"type\": \"number\" },\r",
                  "            \"title\": { \"type\": \"string\" },\r",
                  "            \"slug\": { \"type\": \"string\" },\r",
                  "            \"price\": { \"type\": \"number\" },\r",
                  "            \"description\": { \"type\": \"string\" },\r",
                  "            \"category\": {\r",
                  "                \"type\": \"object\",\r",
                  "                \"required\": [\"id\", \"name\", \"slug\", \"image\"],\r",
                  "                \"properties\": {\r",
                  "                    \"id\": { \"type\": \"number\" },\r",
                  "                    \"name\": { \"type\": \"string\" },\r",
                  "                    \"slug\": { \"type\": \"string\" },\r",
                  "                    \"image\": { \"type\": \"string\", \"format\": \"uri\" }\r",
                  "                }\r",
                  "            },\r",
                  "            \"images\": {\r",
                  "                \"type\": \"array\",\r",
                  "                \"items\": { \"type\": \"string\", \"format\": \"uri\" }\r",
                  "            },\r",
                  "            \"creationAt\": { \"type\": \"string\" },\r",
                  "            \"updatedAt\": { \"type\": \"string\" }\r",
                  "        }\r",
                  "    }\r",
                  "};\r",
                  "\r",
                  "pm.test(\"Validate JSON Schema\", () => {\r",
                  "    pm.response.to.have.jsonSchema(productSchema);\r",
                  "});\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
